{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo \"$PWD\"); bash \"$ROOT/.claude/scripts/session-start.sh\"'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo \"$PWD\"); bash \"$ROOT/.claude/scripts/pre-compact.sh\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo \"$PWD\"); bash \"$ROOT/.claude/scripts/session-end.sh\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo \"$PWD\"); bash \"$ROOT/.claude/scripts/reindex.sh\"'"
          }
        ]
      }
    ]
  }
}
